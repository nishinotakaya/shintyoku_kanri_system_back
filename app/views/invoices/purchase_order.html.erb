<% def fmt_yen(n, blank_when_zero: true)
  return "" if n.nil?
  return "" if blank_when_zero && n.to_i.zero?
  s = n.abs.to_i.to_s.reverse.scan(/\d{1,3}/).join(",").reverse
  n.negative? ? "-#{s}" : s
end
require "base64"
_hanko_path = "#{Rails.root}/public/hanko_nishino.png"
hanko_src = File.exist?(_hanko_path) ? "data:image/png;base64,#{Base64.strict_encode64(File.binread(_hanko_path))}" : nil %>
<!doctype html>
<html lang="ja">
<head>
<meta charset="utf-8">
<title>注文書 <%= data[:order_no] %></title>
<style>
  @page { size: A4; margin: 0; }
  * { box-sizing: border-box; }
  html, body { height: 100%; }
  body {
    font-family: "Hiragino Sans", "Hiragino Kaku Gothic ProN", "Yu Gothic", "Noto Sans CJK JP", sans-serif;
    color: #1a1a1a;
    font-size: 10.5px;
    margin: 0;
    padding: 22px 36px;
    line-height: 1.45;
  }
  h1.title { text-align: center; font-size: 22px; letter-spacing: 8px; margin: 0 0 12px; font-weight: 600; }
  .head { display: flex; justify-content: space-between; gap: 24px; margin-bottom: 10px; }
  .head .recipient { flex: 1; }
  .head .meta { flex: 0 0 36%; font-size: 10px; }
  .meta table { width: 100%; border-collapse: collapse; }
  .meta td { padding: 1px 0; vertical-align: top; }
  .meta td.k { color: #555; width: 40%; }
  .meta td.v { text-align: right; font-variant-numeric: tabular-nums; }
  .recipient-name { font-size: 17px; font-weight: 700; margin-bottom: 4px; }
  .recipient .addr { font-size: 10px; color: #333; }
  .issuer-block {
    margin: 8px 0 10px;
    display: flex; justify-content: space-between; align-items: flex-start; gap: 24px;
  }
  .issuer-block .lead { flex: 1; padding-top: 22px; font-size: 11px; }
  .issuer-block .issuer {
    flex: 0 0 42%; font-size: 10px; position: relative; line-height: 1.4;
  }
  .issuer .name { font-weight: 700; font-size: 12px; margin-bottom: 1px; }
  .hanko-img {
    position: absolute; top: -6px; right: -4px;
    width: 70px; height: 70px;
  }
  .subject-row { display: flex; align-items: baseline; gap: 14px; margin: 10px 0 4px; }
  .subject-row .lbl { font-weight: 700; font-size: 12px; min-width: 52px; }
  .subject-row .val { font-weight: 600; font-size: 13px; }
  .amount-summary { border: 1px solid #888; border-collapse: collapse; width: 58%; margin: 4px 0 12px; }
  .amount-summary th, .amount-summary td { border: 1px solid #888; padding: 4px 8px; text-align: center; font-size: 10px; }
  .amount-summary th { background: #efefef; font-weight: 700; }
  .amount-summary td.total { font-size: 16px; font-weight: 700; }
  table.items { width: 100%; border-collapse: collapse; margin-top: 4px; font-size: 10.5px; }
  table.items th, table.items td { border: 1px solid #888; padding: 4px 7px; vertical-align: middle; }
  table.items th { background: #efefef; font-weight: 700; text-align: center; }
  table.items td.num { text-align: right; font-variant-numeric: tabular-nums; }
  table.items td.qty { text-align: center; white-space: nowrap; }
  .breakdown { width: 50%; margin: 10px 0 8px auto; border: 1px solid #888; border-collapse: collapse; font-size: 10px; }
  .breakdown td { border: 1px solid #888; padding: 3px 8px; }
  .breakdown td.k { width: 58%; background: #fafafa; white-space: nowrap; }
  .breakdown td.v { text-align: right; font-variant-numeric: tabular-nums; }
  .detail-row { display: grid; grid-template-columns: 78px 1fr; gap: 3px 12px; margin-top: 3px; font-size: 10.5px; }
  .detail-row .k { color: #555; }
  .remarks {
    margin-top: 10px; border: 1px solid #888; padding: 6px 10px; font-size: 9.5px;
    line-height: 1.55; white-space: pre-wrap;
  }
  .remarks .h { font-weight: 700; margin-bottom: 1px; font-size: 10px; }
</style>
</head>
<body>
  <h1 class="title">注文書</h1>

  <div class="head">
    <div class="recipient">
      <div class="recipient-name"><%= data[:recipient][:name] %> 様</div>
      <% if data[:recipient][:postal_code].to_s.present? %>
      <div class="addr">〒<%= data[:recipient][:postal_code] %></div>
      <% end %>
      <% data[:recipient][:address].to_s.split("\n").each do |line| %>
      <div class="addr"><%= line %></div>
      <% end %>
    </div>
    <div class="meta">
      <table>
        <tr><td class="k">発注日</td><td class="v"><%= data[:order_date] %></td></tr>
        <tr><td class="k">発注書番号</td><td class="v"><%= data[:order_no] %></td></tr>
      </table>
    </div>
  </div>

  <div class="issuer-block">
    <div class="lead">下記の通り発注致します。</div>
    <div class="issuer">
      <% if hanko_src %>
      <img class="hanko-img" src="<%= hanko_src %>" />
      <% end %>
      <% if data[:issuer][:company_name].to_s.present? %>
      <div class="name"><%= data[:issuer][:company_name] %></div>
      <% end %>
      <div<%= data[:issuer][:company_name].to_s.present? ? "" : ' class="name"'.html_safe %>><%= data[:issuer][:representative] %></div>
      <% if data[:issuer][:postal_code].to_s.present? %>
      <div><%= data[:issuer][:postal_code] %></div>
      <% end %>
      <% data[:issuer][:address].to_s.split("\n").each do |line| %>
      <div><%= line %></div>
      <% end %>
    </div>
  </div>

  <div class="subject-row">
    <span class="lbl">件名</span>
    <span class="val"><%= data[:subject] %></span>
  </div>

  <table class="amount-summary">
    <thead>
      <tr>
        <th>小計</th>
        <th>消費税</th>
        <th>発注金額</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><%= fmt_yen(data[:subtotal], blank_when_zero: false) %>円</td>
        <td><%= fmt_yen(data[:tax], blank_when_zero: false) %>円</td>
        <td class="total"><%= fmt_yen(data[:total], blank_when_zero: false) %>円</td>
      </tr>
    </tbody>
  </table>

  <table class="items">
    <thead>
      <tr>
        <th style="width: 58%;">摘要</th>
        <th style="width: 12%;">数量</th>
        <th style="width: 12%;">単価</th>
        <th style="width: 18%;">明細金額</th>
      </tr>
    </thead>
    <tbody>
      <% data[:items].each do |it| %>
      <tr>
        <td><%= it[:description] %></td>
        <td class="qty"><%= it[:qty] %></td>
        <td class="num"><%= fmt_yen(it[:unit_price]) %></td>
        <td class="num"><%= fmt_yen(it[:amount]) %></td>
      </tr>
      <% end %>
    </tbody>
  </table>

  <table class="breakdown">
    <tr><td class="k">内訳　10%対象(税抜)</td><td class="v"><%= fmt_yen(data[:subtotal], blank_when_zero: false) %>円</td></tr>
    <tr><td class="k">　　　10%消費税</td><td class="v"><%= fmt_yen(data[:tax], blank_when_zero: false) %>円</td></tr>
  </table>

  <div class="detail-row">
    <div class="k">納品期限</div><div><%= data[:delivery_deadline] %></div>
    <div class="k">納品場所</div><div><%= data[:delivery_location] %></div>
    <div class="k">支払方法</div><div><%= data[:payment_method] %></div>
  </div>

  <% if data[:remarks].to_s.strip.length.positive? %>
  <div class="remarks"><div class="h">備考</div><%= data[:remarks] %></div>
  <% end %>
</body>
</html>
