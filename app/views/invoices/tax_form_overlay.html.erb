<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<style>
  /* 国税庁の白紙様式(PNG)を背景に、値を絶対座標(%)で重ね打ちする汎用オーバーレイ */
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: "Hiragino Sans", "Noto Sans JP", sans-serif; }
  .page { position: relative; width: 100vw; height: 100vh; page-break-after: always; overflow: hidden; }
  .page:last-child { page-break-after: auto; }
  .page img.form { position: absolute; inset: 0; width: 100%; height: 100%; }
  .f { position: absolute; color: #111; white-space: nowrap; font-variant-numeric: tabular-nums; }
  .f.right { text-align: right; }
</style>
</head>
<body>
<% pages.each do |page| %>
  <div class="page">
    <img class="form" src="data:image/png;base64,<%= page[:image_base64] %>">
    <% page[:fields].each do |field| %>
      <span class="f <%= field[:align] == :right ? 'right' : '' %>"
            style="left: <%= field[:x] %>%; top: <%= field[:y] %>%; font-size: <%= field[:size] || 11 %>px;<%= field[:align] == :right ? " width: #{field[:w] || 12}%;" : '' %><%= field[:spacing] ? " letter-spacing: #{field[:spacing]}px;" : '' %>">
        <%= field[:text] %>
      </span>
    <% end %>
  </div>
<% end %>
</body>
</html>
